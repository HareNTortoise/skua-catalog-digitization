## Shelfie server/worker environment
## Copy to server/.env and fill the required values.

# --- Core mode ---
# DEBUG=true  -> forces local SQLite (SQLITE_DB_PATH) and does NOT require DATABASE_URL
# DEBUG=false -> requires DATABASE_URL (intended for production)
DEBUG=true

# --- Server ---
PORT=8000

# Default store ID used when the client doesn't provide store_id.
DEFAULT_STORE_ID=hackathon-store

# --- Database ---
# When DEBUG=true, this is the SQLite file path.
SQLITE_DB_PATH=./dev.db

# When DEBUG=false, DATABASE_URL is REQUIRED. Examples:
#   postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME
#   "host=... port=5432 dbname=... user=... password=... sslmode=verify-full sslrootcert=/certs/global-bundle.pem"
DATABASE_URL=

# Connection timeout (seconds) for Postgres.
DB_CONNECT_TIMEOUT_SECONDS=5

# If DB startup fails and DEBUG is not explicitly false, the API can optionally fall back to SQLite.
# Default: enabled on host-local dev, disabled in Docker.
DB_FALLBACK_TO_SQLITE=
# Force detection as running in Docker (mostly for debugging the fallback logic).
DOCKER=

# --- AWS (required for API + worker) ---
AWS_REGION=ap-south-1
AWS_S3_BUCKET=
AWS_SQS_QUEUE_URL=

# Optional: LocalStack (or any custom AWS endpoint) support for S3/SQS.
AWS_ENDPOINT_URL=

# If running without an EC2/ECS role, set static credentials:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# --- Worker tuning ---
# How many frames per second to sample when scanning barcodes.
FRAME_SAMPLE_FPS=1

# --- Quality gate (brightness/blur) ---
# Samples frames quickly and fails early if the video is pitch-black or completely blurry.
QUALITY_GATE_SAMPLE_FPS=1
QUALITY_MIN_MEAN_BRIGHTNESS=18
QUALITY_MIN_LAPLACIAN_VARIANCE=45

# Optional: send a notification email when quality gate fails.
# NOTE: the client can pass `notify_email` when creating a job; if omitted, no email is sent.
BREVO_API_KEY=

# SQS visibility timeout for a received message (seconds).
SQS_VISIBILITY_TIMEOUT_SECONDS=600

# Sleep delay when the worker receives no messages.
WORKER_IDLE_SLEEP_SECONDS=1

# --- LLM (multimodal) ---
# Enable the LLM step (video + answer key). If disabled, the worker only saves deterministic
# results from barcodes + OpenFoodFacts.
ENABLE_LLM=0

# Bedrock model configuration (langchain-aws ChatBedrockConverse)
BEDROCK_MODEL_ID=
BEDROCK_REGION=

# LLM generation controls
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=4096

# Payload limits / media format
LLM_MAX_VIDEO_MB=100
LLM_VIDEO_MIME_TYPE=video/mp4











# --- Tests (opt-in / CI) ---
# Run real AWS integration tests (S3/SQS):
RUN_AWS_INTEGRATION_TESTS=1

# Optional prefix for integration test S3 keys for easier cleanup.
AWS_TEST_PREFIX=integration-tests

# AWS integration test timeouts/retries (seconds / attempts).
AWS_IT_CONNECT_TIMEOUT=5
AWS_IT_READ_TIMEOUT=10
AWS_IT_HTTP_TIMEOUT=10
AWS_IT_MAX_ATTEMPTS=2

# Run real OpenFoodFacts integration test (network call):
RUN_OPENFOODFACTS_INTEGRATION_TESTS=1

# Override barcodes used in the OpenFoodFacts integration test:
# OFF_TEST_BARCODES=8901030916236,8904091121441
OFF_TEST_BARCODES=

# Barcode test sampling rate for server/tests/test_barcode_detection.py
BARCODE_TEST_SAMPLE_FPS=1


